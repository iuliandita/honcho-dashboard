# Honcho API base URL (required).
# Example: https://honcho.example.com
HONCHO_API_BASE=

# Admin bearer token (required). Never leaves the dashboard process.
HONCHO_ADMIN_TOKEN=

# Optional: pin the dashboard to a single workspace.
# When set, the dashboard skips the workspace picker and goes straight to peer list.
# HONCHO_WORKSPACE_ID=

# Optional: listen port. Default 3000.
# PORT=3000

# Optional: log level. info (default) or debug.
# LOG_LEVEL=info

# Optional: upstream Honcho request timeout in seconds. Default 15.
# HONCHO_PROXY_TIMEOUT=15
