# Honcho API base URL (required).
# Example: https://honcho.example.com
HONCHO_API_BASE=

# Admin bearer token (required). Never leaves the dashboard process.
HONCHO_ADMIN_TOKEN=

# Optional: pin the dashboard to a single workspace.
# When set, the dashboard skips the workspace picker and goes straight to peer list.
# HONCHO_WORKSPACE_ID=

# Optional: listen port. Default 3000.
# PORT=3000

# Optional: log level. info (default) or debug.
# LOG_LEVEL=silent is reserved for tests.
# LOG_LEVEL=info

# Optional: upstream Honcho request timeout in seconds. Default 15.
# HONCHO_PROXY_TIMEOUT=15

# Optional: shared-password dashboard auth. Default off.
# DASHBOARD_AUTH_MODE=off
# DASHBOARD_AUTH_MODE=password
# DASHBOARD_AUTH_PASSWORD_HASH=
# DASHBOARD_AUTH_PASSWORD=
# DASHBOARD_SESSION_SECRET=
# DASHBOARD_SESSION_TTL_SECONDS=43200

# Advanced: static build directory served by the Hono process. Default ./build.
# BUILD_DIR=./build

# Only needed by docker-compose.yml's bundled Honcho/Postgres example.
# POSTGRES_PASSWORD=
