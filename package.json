{
  "name": "honcho-dashboard",
  "version": "1.6.3",
  "description": "Self-hosted web inspector for the OSS Honcho server",
  "type": "module",
  "private": false,
  "license": "MIT",
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "build": "svelte-kit sync && vite build && bun build src/server/index.ts --target=bun --outdir=dist --minify",
    "preview": "vite preview",
    "start": "bun run dist/index.js",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "bun run build && playwright test",
    "test:e2e:ui": "bun run build && playwright test --ui",
    "test:e2e:install": "playwright install --with-deps chromium",
    "test:watch": "vitest",
    "codegen": "openapi-typescript src/lib/honcho/openapi.json -o src/lib/honcho/types.ts",
    "refresh-openapi": "./scripts/refresh-honcho-openapi.sh"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "dependencies": {
    "@tanstack/svelte-query": "^6.1.28",
    "dompurify": "^3.4.2",
    "hono": "^4.12.16",
    "marked": "^18.0.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "^2.4.14",
    "@playwright/test": "^1.48.0",
    "@sveltejs/adapter-static": "^3.0.5",
    "@sveltejs/kit": "^2.59.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/svelte": "^5.2.0",
    "@types/bun": "^1.1.0",
    "@types/dompurify": "^3.0.5",
    "@vitest/coverage-v8": "4.1.5",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.4.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.4.7",
    "tailwindcss": "^4.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
